# Claw Recall — Environment Variables
# Copy to .env and configure for your deployment.

# === Required ===
# OpenAI API Key (required for semantic search and embeddings)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# === Embeddings ===
# For local models (Ollama, vLLM, TEI), set the base URL:
# OPENAI_BASE_URL=http://localhost:11434/v1

# === Agent Directories ===
# Additional agent workspaces to search (comma-separated)
# CLAW_RECALL_AGENT_DIRS=/path/to/agent1/workspace,/path/to/agent2/workspace

# === Web Server ===
# CLAW_RECALL_WEB_HOST=127.0.0.1
# CLAW_RECALL_WEB_PORT=8765

# === MCP SSE Server ===
# MCP_SSE_HOST=127.0.0.1
# MCP_SSE_PORT=8766

# === Remote Session Watcher (cc-session-watcher.py) ===
# RECALL_SSH_HOST=your-server
# RECALL_SSH_LOCAL_PORT=18765
# RECALL_SSH_REMOTE_HOST=127.0.0.1
# RECALL_SSH_REMOTE_PORT=8765

# === Remote Indexing ===
# Set this when indexing files pushed from another machine,
# so the indexer knows the source home directory for agent detection.
# CLAW_RECALL_REMOTE_HOME=/home/remoteuser/

# === Health Check (health-check.sh) ===
# CLAW_RECALL_SSE_URL=http://127.0.0.1:8766/sse
# CLAW_RECALL_WEB_URL=http://127.0.0.1:8765/status
# CLAW_RECALL_DB=./convo_memory.db
# CLAW_RECALL_ALERT_SCRIPT=./alert.sh
# CLAW_RECALL_EMB_GAP_THRESHOLD=50000
